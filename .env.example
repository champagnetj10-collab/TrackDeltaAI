# ============================================================
# TrackDelta AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Environment ---
ENVIRONMENT=local   # local | staging | production

# --- Database (PostgreSQL via Supabase) ---
DATABASE_URL=postgresql://trackdelta:password@localhost:5432/trackdelta

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AWS S3 (or Cloudflare R2) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_TELEMETRY=trackdelta-raw-telemetry
S3_BUCKET_PROCESSED=trackdelta-processed-features
S3_BUCKET_DEBRIEFS=trackdelta-debriefs

# --- Anthropic (Delta's voice) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5   # claude-sonnet-4-5 | claude-opus-4

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=delta@trackdelta.ai

# --- Frontend (Next.js — prefix NEXT_PUBLIC_ for client-side) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Limits ---
FREE_TIER_MONTHLY_UPLOADS=3
MAX_UPLOAD_SIZE_MB=250
MIN_LAPS_FOR_ANALYSIS=5
