# ============================================================
# TrackDelta AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Environment ---
ENVIRONMENT=local   # local | staging | production

# --- Database (PostgreSQL via Supabase) ---
DATABASE_URL=postgresql://trackdelta:password@localhost:5432/trackdelta

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
# Set true for local dev without a Redis/worker process running: tasks
# execute synchronously in-process. NEVER set true in staging/production.
CELERY_TASK_ALWAYS_EAGER=false

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
# Settings -> API -> JWT Settings -> JWT Secret in your Supabase project.
# Only set this for projects using the legacy HS256 shared-secret scheme.
# Projects created with the newer asymmetric signing keys have no such
# secret to set — leave this blank and the backend verifies against the
# project's JWKS (/auth/v1/.well-known/jwks.json) instead.
SUPABASE_JWT_SECRET=

# --- File storage (Supabase Storage buckets, created via the Storage API) ---
S3_BUCKET_TELEMETRY=trackdelta-raw-telemetry
S3_BUCKET_PROCESSED=trackdelta-processed-features
S3_BUCKET_DEBRIEFS=trackdelta-debriefs

# --- Anthropic (Delta's voice) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5   # claude-sonnet-4-5 | claude-opus-4

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=delta@trackdelta.ai

# --- Frontend (Next.js — prefix NEXT_PUBLIC_ for client-side) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Limits ---
FREE_TIER_MONTHLY_UPLOADS=3
MAX_UPLOAD_SIZE_MB=250
MIN_LAPS_FOR_ANALYSIS=5
